# ─── Database ───────────────────────────────────────────────────────
# PostgreSQL connection string
# Supabase: use the "Transaction" pooler URL (port 6543) for DATABASE_URL
# Supabase: use the "Session" / direct connection URL (port 5432) for DIRECT_URL
# Both are found in: Supabase dashboard → Project Settings → Database → Connection string
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ─── Server ──────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Auth ────────────────────────────────────────────────────────────
# Use a long random string in production: openssl rand -hex 64
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# ─── CORS ────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:5173,http://localhost:8080

# ─── Email ───────────────────────────────────────────────────────────
# Set to 'sendgrid' or 'smtp' when ready; 'console' logs emails to terminal
EMAIL_PROVIDER=console
EMAIL_FROM=noreply@safeonshift.com
APP_NAME=Safe on Shift
APP_URL=http://localhost:5173

# SendGrid (when EMAIL_PROVIDER=sendgrid)
# SENDGRID_API_KEY=SG.xxxxxxxxxxxx

# SMTP / nodemailer (when EMAIL_PROVIDER=smtp)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASS=yourpassword

# ─── SMS (Twilio) ────────────────────────────────────────────────────
# Set SMS_PROVIDER=twilio and fill in credentials for real SMS alerts
SMS_PROVIDER=console
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+15551234567
